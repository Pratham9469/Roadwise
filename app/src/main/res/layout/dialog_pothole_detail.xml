<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/circle_indicator"
        android:backgroundTint="?attr/glassBorder" />

    <!-- Header Row: Type + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvDetailType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pothole"
                android:textColor="?attr/colorSecondary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDetailDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="2026-03-21 · 20:18"
                android:textColor="?attr/textFaded"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Intensity indicator chip -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?attr/glassSurface"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/glassBorder"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INTENSITY"
                    android:textColor="?attr/textFaded"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
                <TextView
                    android:id="@+id/tvIntensityValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="?attr/colorSecondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Location -->
    <TextView
        android:id="@+id/tvDetailLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:paddingHorizontal="24dp"
        android:text="28.6139° N, 77.2090° E"
        android:textColor="?attr/colorOnSurface"
        android:textSize="14sp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="16dp"
        android:background="?attr/glassBorder" />

    <!-- Photos Section Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="10dp"
        android:text="CAPTURED IMAGES"
        android:textColor="?attr/textFaded"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Photos Scroll -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:scrollbars="none"
        android:clipToPadding="false">
        <LinearLayout
            android:id="@+id/photosContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </HorizontalScrollView>

    <!-- Export Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExportSingle"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:text="Export as PDF"
        android:textColor="?attr/colorSecondary"
        android:letterSpacing="0.05"
        app:cornerRadius="14dp"
        app:strokeColor="?attr/colorSecondary"
        app:icon="@drawable/ic_export"
        app:iconTint="?attr/colorSecondary"
        app:iconGravity="textStart" />

</LinearLayout>
